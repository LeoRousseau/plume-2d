{
  "name": "plume-2d",
  "version": "0.1.0",
  "description": "Lightweight 2D scene graph and rendering library",
  "type": "module",
  "exports": {
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/plume-2d-core.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "license": "MIT",
  "keywords": ["2d", "canvas", "svg", "scene-graph", "rendering"],
  "repository": {
    "type": "git",
    "url": "https://github.com/LeoRousseau/plume-2d"
  },
  "scripts": {
    "dev": "vite --config demo/vite.config.ts",
    "build": "vite build && tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "docs": "typedoc"
  },
  "devDependencies": {
    "cypress": "^15.10.0",
    "happy-dom": "^20.8.9",
    "jsdom": "^28.1.0",
    "typedoc": "^0.28.18",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  }
}
